{
    "replacements": [
        {
            "id": "charger_v6_update",
            "description": "Charger V6 Update for Android 14",
            "type": "unzip_override",
            "source": "devices/common/charger-v6-update.zip",
            "target_base_dir": "build/target/",
            "condition": {
                "android_version": {"min": 14, "max": 14}
            },
            "removes": [
                "odm/bin/hw/vendor.oplus.hardware.charger-V3-service",
                "odm/etc/init/vendor.oplus.hardware.charger-V3-service.rc",
                "odm/lib/vendor.oplus.hardware.charger-V3-ndk_platform.so",
                "odm/lib64/vendor.oplus.hardware.charger-V3-ndk_platform.so"
            ]
        },
        {
            "id": "ril_fix_a13",
            "description": "RIL Fix for A13",
            "type": "unzip_override",
            "source": "devices/common/ril_fix_a13_to_a15.zip",
            "target_base_dir": "build/target/",
            "condition": {
                "android_version": {"min": 13, "max": 13}
            }
        },
        {
            "id": "nfc_fix_a13",
            "description": "NFC Fix for A13",
            "type": "unzip_override",
            "source": "devices/common/nfc_fix_for_a13.zip",
            "target_base_dir": "build/target/",
            "condition": {
                "android_version": {"min": 13, "max": 13}
            },
            "removes": [
                "odm/bin/hw/vendor.oplus.hardware.nfc@1.0-service",
                "odm/etc/init/vendor.oplus.hardware.nfc@1.0-service.rc",
                "odm/etc/vintf/manifest/manifest_oplus_nfc.xml",
                "odm/lib/vendor.oplus.hardware.nfc@1.0.so"
            ]
        },
        {
            "id": "cryptoeng_fix_a13",
            "description": "CryptoEng Fix for A13 (Conditional)",
            "type": "unzip_override",
            "source": "devices/common/cryptoeng_fix_a13.zip",
            "target_base_dir": "build/target/",
            "condition": {
                "and": [
                    {"android_version": {"min": 13, "max": 13}},
                    {"file_exists": "devices/common/cryptoeng_fix_a13.zip"}
                ]
            }
        },
        {
            "id": "clean_a13_services",
            "description": "Clean unnecessary services and manifests for A13",
            "type": "remove_files",
            "condition": {
                "android_version": {"min": 13, "max": 13}
            },
            "files": [
                "odm/bin/hw/vendor.oplus.hardware.charger@1.0-service",
                "odm/bin/hw/vendor.oplus.hardware.wifi@1.1-service",
                "odm/etc/init/vendor.oneplus.faceunlock.hal@1.0-service.rc",
                "odm/etc/init/vendor.oplus.hardware.charger@1.0-service.rc",
                "odm/etc/init/vendor.oplus.hardware.felica@1.0-service.rc",
                "odm/etc/init/vendor.oplus.hardware.midas@1.0-service.rc",
                "odm/etc/init/vendor.oplus.hardware.wifi@1.1-service-qcom.rc",
                "odm/etc/vintf/manifest/manifest_opfaceunlock.xml",
                "odm/etc/vintf/manifest/manifest_oplus_charger.xml",
                "odm/etc/vintf/manifest/manifest_oplus_cryptoeng_hidl.xml",
                "odm/etc/vintf/manifest/manifest_oplus_felica.xml",
                "odm/etc/vintf/manifest/manifest_oplus_midas.xml",
                "odm/etc/vintf/manifest/oplus_wifi_service_device.xml",
                "odm/framework/vendor.oplus.hardware.wifi-V1.1-java.jar",
                "odm/lib/vendor.oneplus.faceunlock.hal@1.0.so",
                "odm/lib/vendor.oneplus.faceunlock.hal-V1-ndk_platform.so",
                "odm/lib64/vendor.oneplus.faceunlock.hal@1.0.so",
                "odm/lib64/vendor.oneplus.faceunlock.hal-V1-ndk_platform.so",
                "odm/lib64/vendor.oplus.hardware.felica@1.0-impl.so",
                "odm/lib64/vendor.oplus.hardware.felica@1.0.so",
                "odm/lib64/vendor.oplus.hardware.subsys_radio-V1-ndk_platform.so",
                "odm/lib64/vendor.oplus.hardware.subsys-V1-ndk_platform.so",
                "odm/lib64/vendor.oplus.hardware.wifi@1.1.so"
            ]
        },
        {
            "id": "remove_qualcomm_location",
            "description": "Remove Qualcomm Location for A16 Port",
            "type": "remove_files",
            "condition": {
                "and": [
                    {"port_android_version": {"min": 16, "max": 16}},
                    {"base_android_version": {"max": 15}}
                ]
            },
            "files": ["system_ext/priv-app/com.qualcomm.location"]
        },
        {
            "id": "nfc_fix_a16_v2",
            "description": "NFC Fix A16 V2",
            "type": "unzip_override",
            "source": "devices/common/nfc_fix_a16_v2.zip",
            "target_base_dir": "build/target/",
            "condition": {
                "and": [
                    {"port_android_version": {"min": 16, "max": 16}},
                    {"base_android_version": {"max": 14}},
                    {"file_exists": "devices/common/nfc_fix_a16_v2.zip"}
                ]
            },
            "removes": ["system/system/priv-app/NfcNci"]
        },
        {
            "id": "wifi_fix_a16_cn",
            "description": "WIFI Fix A16 (CN)",
            "type": "unzip_override",
            "source": "devices/common/wifi_fix_a16.zip",
            "target_base_dir": "build/target/",
            "condition": {
                "and": [
                    {"port_android_version": {"min": 16, "max": 16}},
                    {"base_android_version": {"max": 14}},
                    {"region": "CN"}
                ]
            },
            "removes": ["system/system/apex/com.google.android.wifi.apex"]
        },
        {
            "id": "oos_1601_fix_global",
            "description": "OOS 1601 Fix (Global)",
            "type": "unzip_override",
            "source": "devices/common/oos_1601_fix.zip",
            "target_base_dir": "build/target/",
            "condition": {
                "and": [
                    {"port_android_version": {"min": 16, "max": 16}},
                    {"base_android_version": {"max": 14}},
                    {"rom_version": {"contains": "16.0.1"}},
                    {"not": {"region": "CN"}}
                ]
            }
        },
        {
            "id": "power_profile_copy",
            "description": "Internal Power Profile Copy",
            "type": "copy_file_internal",
            "source": "odm/etc/power_profile/power_profile.xml",
            "target": "my_product/cust/CN/etc/power_profile/power_profile.xml",
            "condition": {
                "target_exists": true
            }
        },
        {
            "id": "copy_multimedia_xml",
            "description": "Copy Multimedia XML files from baserom",
            "type": "copy_files_from_stock",
            "source": "my_product/etc/Multimedia_*.xml",
            "target_dir": "my_product/etc/"
        },
        {
            "id": "conditional_copy_sys_graphic_enhancement",
            "description": "Copy sys_graphic_enhancement_config.json if exists in baserom",
            "type": "conditional_copy",
            "source": "my_product/etc/extension/sys_graphic_enhancement_config.json",
            "target": "my_product/etc/extension/sys_graphic_enhancement_config.json"
        },
        {
            "id": "sync_overlay_files",
            "description": "Sync overlay files from baserom",
            "type": "overlay_sync",
            "copy_vendor": true,
            "remove_patterns": ["*display*[0-9]*.apk"],
            "overlay_pattern": "*{my_product_type}*.apk"
        }
    ]
}
