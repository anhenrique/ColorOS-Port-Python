{
    "replacements": [
        {
            "id": "camera5_fix_cos",
            "description": "ColorOS 15 Camera Fix (CN)",
            "type": "unzip_override_group",
            "condition": {
                "and": [
                    {"rom_type": "ColorOS"},
                    {"port_android_version": {"min": 15, "max": 15}},
                    {"file_exists": "devices/target/ONEPLUS9PRO/assets/camera5.0-fix_cos.zip"}
                ]
            },
            "operations": [
                {
                    "id": "camera5_cos_framework",
                    "description": "Camera 5.0 Framework (ColorOS)",
                    "type": "unzip_override",
                    "source": "devices/target/ONEPLUS9PRO/assets/camera5.0-fix_cos.zip",
                    "target_base_dir": "build/target/",
                    "removes": [
                        "my_product/app/OplusCamera",
                        "my_product/product_overlay/framework/com.oplus.camera.*.jar"
                    ],
                    "build_props": {
                        "my_product": {
                            "ro.vendor.oplus.camera.isSupportLumo": "1"
                        }
                    }
                },
                {
                    "id": "camera5_odm",
                    "description": "Camera 5.0 ODM Files",
                    "type": "unzip_override",
                    "source": "devices/target/ONEPLUS9PRO/assets/camera5.0-fix_odm.zip",
                    "target_base_dir": "build/target/"
                }
            ]
        },
        {
            "id": "camera6_fix_cos",
            "description": "ColorOS 16 Camera Fix (CN)",
            "type": "unzip_override_group",
            "condition": {
                "and": [
                    {"rom_type": "ColorOS"},
                    {"port_android_version": {"min": 16, "max": 16}},
                    {"file_exists": "devices/target/ONEPLUS9PRO/assets/camera6.0-fix_odm.zip"}
                ]
            },
