                            "ro.vendor.oplus.camera.isSupportLumo": "1"
                        }
                    }
                },
                {
                    "id": "camera6_odm",
                    "description": "Camera 6.0 ODM Files",
                    "type": "unzip_override",
                    "source": "devices/target/ONEPLUS9PRO/assets/camera6.0-fix_odm.zip",
                    "target_base_dir": "build/target/"
                }
            ]
        },
        {
            "id": "camera5_fix_oos",
            "description": "OxygenOS 15 Camera Fix",
            "type": "unzip_override_group",
            "condition": {
                "and": [
                    {"rom_type": "OxygenOS"},
                    {"port_android_version": {"min": 15, "max": 15}},
                    {"file_exists": "devices/target/ONEPLUS9PRO/assets/camera5.0-fix_oos.zip"}
                ]
            },
            "operations": [
                {
                    "id": "camera5_oos_framework",
                    "description": "Camera 5.0 Framework (OxygenOS)",
                    "type": "unzip_override",
                    "source": "devices/target/ONEPLUS9PRO/assets/camera5.0-fix_oos.zip",
                    "target_base_dir": "build/target/",
                    "removes": [
                        "my_product/app/OplusCamera",
